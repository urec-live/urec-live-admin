{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://urec-live-backend.railway.internal.up.railway.app/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "https://urec-live-backend.railway.internal.up.railway.app/ws/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
